        "for persona in ['conservative', 'balanced', 'aggressive']:\n",
        "    rm = reward_models[persona]\n",
        "    env = make_env(df_train, mode='train', reward_model=rm,\n",
        "                   rlhf_lambda=RLHF_LAMBDA, seed=42)\n",
        "    obs, _ = env.reset()\n",
        "    persona_rewards = []\n",
        "    base_rewards = []\n",
        "    done = False\n",
        "    while not done:\n",
        "        action, _ = base_agent.predict(obs, deterministic=True)\n",
        "        obs, total, term, trunc, info = env.step(action)\n",
        "        done = term or trunc\n",
        "        persona_rewards.append(float(info.get('rlhf_reward', 0)) * RLHF_LAMBDA)\n",
        "        base_rewards.append(float(info.get('base_reward', 0)))\n",
        "    env.close()\n",
