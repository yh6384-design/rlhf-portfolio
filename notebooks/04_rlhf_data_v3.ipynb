      "cell_type": "code",
      "source": [
        "df = pd.read_parquet(f'{DATA_DIR}/preferences.parquet')\n",
        "\n",
        "# How often does each rule fire for label_conservative?\n",
        "n = len(df)\n",
        "dead_a = ((df['traj_a_turnover'] < 0.01) & (df['traj_a_annualized_return'].abs() < 0.01))\n",
        "dead_b = ((df['traj_b_turnover'] < 0.01) & (df['traj_b_annualized_return'].abs() < 0.01))\n",
        "print(f'Total pairs: {n}')\n",
        "print(f'  traj_a is \"dead\" trajectory: {dead_a.sum()} ({dead_a.mean():.1%})')\n",
        "print(f'  traj_b is \"dead\" trajectory: {dead_b.sum()} ({dead_b.mean():.1%})')\n",
        "print(f'  Pairs where dead-rule decides: {(dead_a ^ dead_b).sum()} ({(dead_a ^ dead_b).mean():.1%})')\n",
        "\n",
        "# Label distribution\n",
        "for col in ['label_conservative', 'label_balanced', 'label_aggressive']:\n",
        "    print(f'\\n{col}: {df[col].value_counts(normalize=True).to_dict()}')"
