    {
      "cell_type": "code",
      "source": [
        "# ── Augment preferences with synthetic cash trajectories (cash-bug fix) ─────\n",
        "# Pairs literal cash trajectories against ONLY clearly-good active trajectories\n",
        "# so cash unambiguously loses under all 3 persona rules.\n",
        "\n",
        "N_CASH_PAIRS = 20\n",
        "\n",
        "def make_cash_summary(pair_id):\n",
        "    \"\"\"Synthetic 'all cash, never trades' trajectory — all features at zero.\"\"\"\n",
        "    return {\n",
        "        'window_id':         f'CASH_SYNTHETIC_{pair_id}',\n",
        "        'source':            'synthetic_cash',\n",
        "        'start_date':        pd.Timestamp('2015-01-01'),\n",
        "        'end_date':          pd.Timestamp('2015-03-30'),\n",
        "        'n_days':            60,\n",
        "        'annualized_return': 0.0,\n",
        "        'sharpe':            0.0,\n",
        "        'max_drawdown':      0.0,\n",
        "        'volatility':        0.0,\n",
        "        'calmar':            0.0,\n",
        "        'turnover':          0.0,\n",
        "    }\n",
        "\n",
        "# Filter: only pair cash against trajectories where cash unambiguously loses\n",
        "# under ALL 3 persona rules\n",
        "good_mask = (\n",
        "    (windows_df['annualized_return'] > 0.05) &   # clear positive return\n",
        "    (windows_df['sharpe']            > 0.20) &   # clears balanced's 0.10 threshold\n",
        "    (windows_df['calmar']            > 0.5)      # positive risk/reward\n",
        ")\n",
        "good_pool = windows_df[good_mask]\n",
        "print(f'Good-active pool: {len(good_pool)} of {len(windows_df)} windows')\n",
        "\n",
        "if len(good_pool) < N_CASH_PAIRS:\n",
        "    raise ValueError(f'Not enough good trajectories. Found {len(good_pool)}, need {N_CASH_PAIRS}.')\n",
        "\n",
        "rng = np.random.default_rng(seed=12345)\n",
        "chosen_idx = rng.choice(len(good_pool), size=N_CASH_PAIRS, replace=False)\n",
        "active_trajs = good_pool.iloc[chosen_idx].to_dict(orient='records')\n",
        "\n",
        "# Build synthetic pairs — alternate which side cash is on, for label balance\n",
        "cash_pair_rows = []\n",
        "for i, active in enumerate(active_trajs):\n",
        "    cash_pair_id = len(preferences_df) + i\n",
        "    cash = make_cash_summary(cash_pair_id)\n",
        "\n",
        "    if i % 2 == 0:\n",
        "        # cash on side A → all 3 personas should label \"B wins\" (= 0)\n",
        "        row = build_preference_row(cash, active, pair_id=cash_pair_id)\n",
        "    else:\n",
        "        # cash on side B → all 3 personas should label \"A wins\" (= 1)\n",
        "        row = build_preference_row(active, cash, pair_id=cash_pair_id)\n",
        "    cash_pair_rows.append(row)\n",
        "\n",
        "cash_df = pd.DataFrame(cash_pair_rows)\n",
        "\n",
        "# Verify cash always loses — should be 0 violations\n",
        "violations = 0\n",
        "for _, row in cash_df.iterrows():\n",
        "    cash_is_a = (row['traj_a_source'] == 'synthetic_cash')\n",
        "    expected = 0 if cash_is_a else 1\n",
        "    for persona in ['conservative', 'balanced', 'aggressive']:\n",
        "        if row[f'label_{persona}'] != expected:\n",
        "            violations += 1\n",
        "            print(f'  ⚠ pair {row[\"pair_id\"]} ({persona}): got {row[f\"label_{persona}\"]}, expected {expected}')\n",
        "\n",
        "if violations == 0:\n",
        "    print(f'✓ All {N_CASH_PAIRS} synthetic cash pairs label cash as the loser for all 3 personas.')\n",
        "else:\n",
        "    print(f'✗ {violations} violations — STOP, filter is not strict enough.')\n",
        "\n",
        "# Append to main preferences dataframe\n",
        "preferences_df = pd.concat([preferences_df, cash_df], axis=0, ignore_index=True)\n",
        "\n",
        "print(f'\\nDataset size: {len(preferences_df)} pairs ({N_CASH_PAIRS} synthetic cash, {len(preferences_df) - N_CASH_PAIRS} real)')\n",
        "print(f'Synthetic cash share: {N_CASH_PAIRS / len(preferences_df):.1%}')\n",
        "print(f'\\nUpdated label distribution:')\n",
        "for col in ['label_conservative', 'label_balanced', 'label_aggressive']:\n",
        "    print(f'  {col}: {preferences_df[col].value_counts(normalize=True).to_dict()}')"
      ],
