        "        \"rows\": len(df),\n",
        "        \"n_dates\": df[\"date\"].nunique(),\n",
        "        \"n_tickers\": df[\"tic\"].nunique(),\n",
        "        \"date_min\": df[\"date\"].min(),\n",
        "        \"date_max\": df[\"date\"].max(),\n",
        "    }\n",
        "\n",
        "summary_df = pd.DataFrame([\n",
        "    dataset_summary(df_train, \"train\"),\n",
        "    dataset_summary(df_val, \"val\"),\n",
        "    dataset_summary(df_test, \"test\"),\n",
        "])\n",
        "\n",
        "display(summary_df)"
