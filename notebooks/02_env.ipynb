        "def build_validation_report():\n",
        "    report = {\n",
        "        \"train_wide_rows\": len(df_train_wide),\n",
        "        \"val_wide_rows\": len(df_val_wide),\n",
        "        \"test_wide_rows\": len(df_test_wide),\n",
        "        \"train_long_rows\": len(df_train),\n",
